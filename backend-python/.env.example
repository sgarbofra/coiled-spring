# Copy this file to .env and fill in your values
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5433/coiled_spring
SECRET_KEY=change-this-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Encryption key for sensitive data (API keys, etc.)
# Generate a new key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Or run: python backend-python/app/core/encryption.py
ENCRYPTION_KEY=your-fernet-key-here

# Production domain(s) — comma separated
# CORS_ORIGINS=https://coiledspring.app

# Stripe configuration
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email configuration (Resend)
RESEND_API_KEY=re_...

# Email testing (development only)
# When TEST_EMAIL is set, all emails are redirected to this address
# In production, leave this unset to send emails to real user addresses
TEST_EMAIL=your.dev.email@example.com

# Admin configuration
ADMIN_KEY=your-secret-admin-key
ADMIN_EMAIL=sgarbo.fra@gmail.com
ADMIN_SECRET=coiledspring_dev

# Development mode (set to False in production)
DEBUG=True

# IBKR Connection (Pro plan only)
# Port 7497 = TWS Paper Trading, 7496 = TWS Live, 4001 = IB Gateway Paper
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
